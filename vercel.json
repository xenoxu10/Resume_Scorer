{
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": "public",
  "framework": "fastapi",
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "OPENAI_API_KEY": "@openai_api_key",
    "ENVIRONMENT": "production"
  }
}
