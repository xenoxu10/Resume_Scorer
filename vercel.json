{
  "buildCommand": "pip install --no-cache-dir -r requirements.txt",
  "outputDirectory": "public",
  "framework": "fastapi",
  "python": {
    "version": "3.12"
  },
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "includeFiles": "backend/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
